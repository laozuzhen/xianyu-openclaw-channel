{
  "name": "xianyu-channel-plugin",
  "version": "0.1.0",
  "description": "Xianyu (闲鱼) channel plugin for OpenClaw (Bridge Mode)",
  "keywords": [
    "bot",
    "channel",
    "openclaw",
    "xianyu",
    "goofish",
    "闲鱼",
    "bridge"
  ],
  "license": "MIT",
  "files": [
    "index.ts",
    "src/*.ts",
    "openclaw.plugin.json"
  ],
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "test": "vitest run",
    "type-check": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "eventsource": "^3.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.13"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channels": [
      "xianyu"
    ],
    "installDependencies": true,
    "channel": {
      "id": "xianyu",
      "label": "Xianyu",
      "selectionLabel": "Xianyu (闲鱼)",
      "blurb": "闲鱼二手交易平台消息频道（桥接模式）",
      "order": 80,
      "aliases": [
        "xy",
        "goofish"
      ]
    },
    "install": {
      "localPath": ".",
      "defaultChoice": "npm"
    }
  }
}
